# Copy to ".env" and fill in. Vite only exposes vars prefixed with VITE_.

# --- Cloudflare Turnstile (bot protection on signup/login) ---
# Free key: https://dash.cloudflare.com/?to=/:account/turnstile
# If unset, the app uses Cloudflare's public TEST key (always passes).
VITE_TURNSTILE_SITE_KEY=

# --- Supabase (backend — wired up in a later lesson) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
